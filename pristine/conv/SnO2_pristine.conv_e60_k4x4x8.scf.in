! AUTO-GENERATED by conv_test.py — convergence test, do not hand-edit.
! Single-point SCF derived from SnO2_pristine/relax; only ecutwfc/k-mesh vary.
&CONTROL
  calculation = 'scf'
  prefix = 'SnO2_pristine_e60_k4x4x8'
  outdir = './tmp'
  pseudo_dir = '../../pseudo'
  tprnfor = .true.
  tstress = .true.
/

&SYSTEM
  ibrav = 0
  nat = 24
  ntyp = 2
  ecutwfc = 60
  ecutrho = 480
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.01
  nspin = 1
/

&ELECTRONS
  conv_thr = 1.0e-8
  mixing_beta = 0.4
  mixing_mode = 'plain'
  electron_maxstep = 200
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  9.474000   0.000000   0.000000
  0.000000   9.474000   0.000000
  0.000000   0.000000   3.186000

