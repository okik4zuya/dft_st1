&CONTROL
  calculation   = 'nscf'
  prefix        = 'SnO2_pristine'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
/

&SYSTEM
  ibrav         = 0
  nat           = 24
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  nbnd          = 160            ! ~1.5x occupied (104); matches bands.in
  occupations   = 'tetrahedra_opt'
  nosym         = .true.         ! required for epsilon.x: full BZ k-point set
  nspin         = 1
/

&ELECTRONS
  conv_thr           = 1.0e-9
  electron_maxstep   = 300
  diagonalization    = 'cg'
  diago_cg_maxiter   = 200
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

