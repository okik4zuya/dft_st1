&CONTROL
  calculation   = 'nscf'
  prefix        = 'SnO2_2to1'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
/

&SYSTEM
  ibrav         = 0
  nat           = 21
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  nbnd          = 200          ! more bands needed: 3 Vo create denser sub-gap states
  occupations   = 'tetrahedra_opt'
  nspin         = 2
  tot_charge       = 0.0
/

&ELECTRONS
  conv_thr         = 1.0e-10
  electron_maxstep = 300
  diagonalization  = 'cg'      ! avoid Davidson 'cdiaghg (227): problems
                               ! computing cholesky' on the band step
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  9.474000   0.000000   0.000000
  0.000000   9.474000   0.000000
  0.000000   0.000000   3.186000

