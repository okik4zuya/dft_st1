&CONTROL
  calculation   = 'vc-relax'
  prefix        = 'SnO2_2to1'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
  tprnfor       = .true.
  tstress       = .true.
  forc_conv_thr = 1.0e-4
  etot_conv_thr = 1.0e-5
/

&SYSTEM
  ibrav         = 0
  nat           = 21           ! 8 Sn + 13 O (3 Vo removed from 2x2x1)
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  occupations   = 'smearing'
  smearing      = 'mv'
  degauss       = 0.01
  nspin         = 2            ! spin-polarised: 3 Vo donate 6 electrons total
  starting_magnetization(1) = 0.5   ! Sn
  starting_magnetization(2) = 0.0   ! O
  tot_charge       = 0.0
/

&ELECTRONS
  conv_thr         = 1.0e-8
  mixing_beta      = 0.2       ! lower mixing: 3 Vo causes stronger charge sloshing
  mixing_mode      = 'local-TF'
  electron_maxstep = 400
/

&IONS
  ion_dynamics  = 'bfgs'
/

&CELL
  cell_dynamics  = 'bfgs'
  press_conv_thr = 0.5
  cell_factor    = 2.0
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  9.474000   0.000000   0.000000
  0.000000   9.474000   0.000000
  0.000000   0.000000   3.186000

! 3 Vo placed in triangular arrangement for maximum mutual separation
! Removed O sites: O14, O22, O8 from pristine 2x2x1
! This gives a roughly symmetric Vo distribution across the supercell
! IMPORTANT: Test at least 3 configurations; use lowest total energy for production
ATOMIC_POSITIONS angstrom
  Sn   0.000000   0.000000   0.000000
  Sn   2.368500   2.368500   1.593000
  Sn   4.737000   0.000000   0.000000
  Sn   7.105500   2.368500   1.593000
  Sn   0.000000   4.737000   0.000000
  Sn   2.368500   7.105500   1.593000
  Sn   4.737000   4.737000   0.000000
  Sn   7.105500   7.105500   1.593000
  O    1.454259   1.454259   0.000000   ! O1
  O    3.822759   0.914241   1.593000   ! O3
  O    0.914241   3.822759   1.593000   ! O4
  O    6.191259   1.454259   0.000000   ! O5
  O    8.559759   0.914241   1.593000   ! O7
  O    5.651241   3.822759   1.593000   ! O8
  O    1.454259   6.191259   0.000000   ! O9
  O    3.282741   8.019741   0.000000   ! O10
  O    3.822759   5.651241   1.593000   ! O11
  O    0.914241   8.559759   1.593000   ! O12
  O    6.191259   6.191259   0.000000   ! O13
  O    8.559759   5.651241   1.593000   ! O15
  O    5.651241   8.559759   1.593000   ! O16

! Vo positions (corrected from wrong pristine structure):
!   Vo#1: (3.282741, 3.282741, 0.000) A
!   Vo#2: (8.019741, 8.019741, 0.000) A
!   Vo#3: (8.019741, 3.282741, 0.000) A  [NOTE: was intended as z=c/2 in old wrong file]
! Vo#1-Vo#2 distance: 6.70 A
! Vo#1-Vo#3 distance: 4.74 A
! Vo#2-Vo#3 distance: 4.74 A
! Right-isoceles triangle arrangement (legs 4.74 A, hypotenuse 6.70 A)

K_POINTS automatic
  4 4 8  0 0 0

HUBBARD (ortho-atomic)
  U Sn-4d 4.0
  U O-2p  0.0
