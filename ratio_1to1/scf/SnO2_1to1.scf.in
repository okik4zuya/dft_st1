&CONTROL
  calculation   = 'scf'
  prefix        = 'SnO2_1to1'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
  tprnfor       = .true.
  tstress       = .true.
/

&SYSTEM
  ibrav         = 0
  nat           = 22           ! 8 Sn + 14 O (2 Vo, 12.50% Vo)
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  occupations   = 'smearing'
  smearing      = 'mv'
  degauss       = 0.01
  nspin         = 2
  starting_magnetization(1) = 0.5
  starting_magnetization(2) = 0.0
  tot_charge       = 0.0
/

&ELECTRONS
  conv_thr         = 1.0e-8
  mixing_beta      = 0.3
  mixing_mode      = 'local-TF'
  electron_maxstep = 300
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

