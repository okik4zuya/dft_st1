&CONTROL
  calculation   = 'vc-relax'
  prefix        = 'SnO2_1to1'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
  tprnfor       = .true.
  tstress       = .true.
  forc_conv_thr = 1.0e-4
  etot_conv_thr = 1.0e-5
/

&SYSTEM
  ibrav         = 0
  nat           = 22           ! 8 Sn + 14 O (2 Vo removed from 2x2x1)
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  occupations   = 'smearing'
  smearing      = 'mv'
  degauss       = 0.01
  nspin         = 2            ! spin-polarised: 2 Vo donate 4 electrons
  starting_magnetization(1) = 0.5   ! Sn â€” try FM; compare with AFM
  starting_magnetization(2) = 0.0   ! O
  tot_charge       = 0.0       ! neutral supercell
/

&ELECTRONS
  conv_thr         = 1.0e-8
  mixing_beta      = 0.3       ! lower than pristine: Vo can cause oscillations
  mixing_mode      = 'local-TF'
  electron_maxstep = 300
/

&IONS
  ion_dynamics  = 'bfgs'
/

&CELL
  cell_dynamics  = 'bfgs'
  press_conv_thr = 0.5
  cell_factor    = 2.0
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  9.474000   0.000000   0.000000
  0.000000   9.474000   0.000000
  0.000000   0.000000   3.186000

! 2 Vo placed at maximally separated O sites to minimise image interaction
! Removed O sites: O14 (index 22) and O22 (index 30) from pristine 2x2x1
! These are next-nearest-neighbour vacancies (~6.7 A apart)
! Run multiple configs (nearest/next-nearest/max-separation) and use lowest E
ATOMIC_POSITIONS angstrom
  Sn   0.000000   0.000000   0.000000
  Sn   2.368500   2.368500   1.593000
  Sn   4.737000   0.000000   0.000000
  Sn   7.105500   2.368500   1.593000
  Sn   0.000000   4.737000   0.000000
  Sn   2.368500   7.105500   1.593000
  Sn   4.737000   4.737000   0.000000
  Sn   7.105500   7.105500   1.593000
  O    1.454259   1.454259   0.000000   ! O1
  !                                     ! O2 REMOVED -> Vo #1 (3.282741,3.282741,0)
  O    3.822759   0.914241   1.593000   ! O3
  O    0.914241   3.822759   1.593000   ! O4
  O    6.191259   1.454259   0.000000   ! O5
  O    8.019741   3.282741   0.000000   ! O6
  O    8.559759   0.914241   1.593000   ! O7
  O    5.651241   3.822759   1.593000   ! O8
  O    1.454259   6.191259   0.000000   ! O9
  O    3.282741   8.019741   0.000000   ! O10
  O    3.822759   5.651241   1.593000   ! O11
  O    0.914241   8.559759   1.593000   ! O12
  O    6.191259   6.191259   0.000000   ! O13
  !                                     ! O14 REMOVED -> Vo #2 (8.019741,8.019741,0)
  O    8.559759   5.651241   1.593000   ! O15
  O    5.651241   8.559759   1.593000   ! O16

! Vo #1 site: (3.282741, 3.282741, 0.000) A -- between Sn at (0,0,0) and (4.737,4.737,0)
! Vo #2 site: (8.019741, 8.019741, 0.000) A -- between Sn at (4.737,4.737,0) and periodic image
! Vo separation: 4.737*sqrt(2) = 6.70 A (next-nearest neighbour configuration)

K_POINTS automatic
  4 4 8  0 0 0

HUBBARD (ortho-atomic)
  U Sn-4d 4.0
  U O-2p  0.0
