&CONTROL
  calculation   = 'nscf'
  prefix        = 'SnO2_1to1'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
/

&SYSTEM
  ibrav         = 0
  nat           = 22
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  nbnd          = 180          ! spin-up + spin-down; include all Vo states + conduction
  occupations   = 'tetrahedra_opt'
  nspin         = 2
  tot_charge       = 0.0
/

&ELECTRONS
  conv_thr           = 1.0e-9    ! plenty for nscf DOS; 1e-10 left top bands unconv.
  electron_maxstep   = 300
  diagonalization    = 'david'   ! Davidson (verified stable, ~28x faster than cg)
  diago_david_ndim   = 2         ! small subspace avoids cdiaghg cholesky singularity
  diago_full_acc     = .true.    ! converge empty bands (they caused the cholesky fail)
/

ATOMIC_SPECIES
  Sn  118.710  Sn.pbesol-dn-kjpaw_psl.1.0.0.UPF
  O   15.999   O.pbesol-n-kjpaw_psl.1.0.0.UPF

! Use relaxed coordinates
