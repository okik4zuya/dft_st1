&CONTROL
  calculation   = 'bands'
  prefix        = 'TiO2_pristine'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
/

&SYSTEM
  ibrav         = 0
  nat           = 24
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  nbnd          = 160
  nspin         = 1
/

&ELECTRONS
  conv_thr         = 1.0e-10
  electron_maxstep = 300
  diagonalization  = 'cg'      ! avoid Davidson 'cdiaghg (227): problems
                               ! computing cholesky' on the band step
/

ATOMIC_SPECIES
  Ti  47.867  Ti.pbesol-spn-kjpaw_psl.1.0.0.UPF
  O   15.999  O.pbesol-n-kjpaw_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
  9.188000   0.000000   0.000000
  0.000000   9.188000   0.000000
  0.000000   0.000000   2.959000

ATOMIC_POSITIONS angstrom
  Ti   0.000000   0.000000   0.000000
  Ti   2.297000   2.297000   1.479500
  Ti   4.594000   0.000000   0.000000
  Ti   6.891000   2.297000   1.479500
  Ti   0.000000   4.594000   0.000000
  Ti   2.297000   6.891000   1.479500
  Ti   4.594000   4.594000   0.000000
  Ti   6.891000   6.891000   1.479500
  O    1.406000   1.406000   0.000000
  O    7.782000   7.782000   0.000000
  O    0.891000   3.188000   1.479500
  O    3.188000   0.891000   1.479500
  O    5.985000   1.406000   0.000000
  O    3.703000   3.703000   0.000000
  O    5.485000   0.891000   1.479500
  O    7.782000   3.188000   1.479500
  O    1.406000   5.985000   0.000000
  O    3.703000   8.282000   0.000000
  O    0.891000   7.485000   1.479500
  O    3.188000   5.188000   1.479500
  O    5.985000   5.985000   0.000000
  O    8.282000   8.282000   0.000000
  O    5.485000   5.485000   1.479500
  O    7.782000   7.782000   1.479500

! High-symmetry path for rutile tetragonal (same as SnO2)
! Verify with SeeK-path: https://seekpath.materialscloud.org
K_POINTS crystal_b
  8
  0.000  0.000  0.000   50   ! Gamma
  0.500  0.500  0.000   40   ! M
  0.500  0.000  0.000   30   ! X
  0.000  0.000  0.000   50   ! Gamma
  0.000  0.000  0.500   30   ! Z
  0.500  0.500  0.500   40   ! R
  0.500  0.000  0.500   30   ! A
  0.000  0.000  0.500    1   ! Z

HUBBARD (ortho-atomic)
  U Ti-3d 4.2
  U O-2p  0.0
