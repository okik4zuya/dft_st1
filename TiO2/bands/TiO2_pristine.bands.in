&CONTROL
  calculation   = 'bands'
  prefix        = 'TiO2_pristine'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
/

&SYSTEM
  ibrav         = 0
  nat           = 24
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  nbnd          = 160
  nspin         = 1
/

&ELECTRONS
  conv_thr           = 1.0e-9    ! plenty for bands; 1e-10 left top bands unconv.
  electron_maxstep   = 300
  diagonalization    = 'david'   ! Davidson (verified stable, ~28x faster than cg)
  diago_david_ndim   = 2         ! small subspace avoids cdiaghg cholesky singularity
  diago_full_acc     = .true.    ! converge empty bands (they caused the cholesky fail)
/

ATOMIC_SPECIES
  Ti  47.867  Ti.pbesol-spn-kjpaw_psl.1.0.0.UPF
  O   15.999  O.pbesol-n-kjpaw_psl.1.0.0.UPF

