! AUTO-GENERATED by conv_test.py — convergence test, do not hand-edit.
! Single-point SCF derived from TiO2_pristine/relax; only ecutwfc/k-mesh vary.
&CONTROL
  calculation = 'scf'
  prefix = 'TiO2_pristine_e60_k4x4x8'
  outdir = './tmp'
  pseudo_dir = '../../pseudo'
  tprnfor = .true.
  tstress = .true.
/

&SYSTEM
  ibrav = 0
  nat = 24
  ntyp = 2
  ecutwfc = 60
  ecutrho = 480
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.01
  nspin = 1
/

&ELECTRONS
  conv_thr = 1.0e-8
  mixing_beta = 0.4
  mixing_mode = 'plain'
  electron_maxstep = 200
/

ATOMIC_SPECIES
  Ti  47.867  Ti.pbesol-spn-kjpaw_psl.1.0.0.UPF
  O   15.999  O.pbesol-n-kjpaw_psl.1.0.0.UPF

