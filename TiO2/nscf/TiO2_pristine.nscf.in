&CONTROL
  calculation   = 'nscf'
  prefix        = 'TiO2_pristine'
  outdir        = './tmp'
  pseudo_dir    = '../../pseudo'
/

&SYSTEM
  ibrav         = 0
  nat           = 24
  ntyp          = 2
  ecutwfc       = 60
  ecutrho       = 480
  nbnd          = 160          ! ~2.5x occupied bands (TiO2 has ~64 occ bands)
  occupations   = 'tetrahedra_opt'
  nosym         = .true.         ! required for epsilon.x: full BZ k-point set
  nspin         = 1
/

&ELECTRONS
  conv_thr           = 1.0e-9    ! plenty for nscf DOS; 1e-10 left top bands unconv.
  electron_maxstep   = 300
  diagonalization    = 'cg'      ! avoid Davidson 'cdiaghg (227): problems
                                 ! computing cholesky' on the band step
  diago_cg_maxiter   = 200       ! default 20 -> 'eigenvalues not converged'
/

ATOMIC_SPECIES
  Ti  47.867  Ti.pbesol-spn-kjpaw_psl.1.0.0.UPF
  O   15.999  O.pbesol-n-kjpaw_psl.1.0.0.UPF

! Use relaxed coordinates from vc-relax
CELL_PARAMETERS angstrom
  9.188000   0.000000   0.000000
  0.000000   9.188000   0.000000
  0.000000   0.000000   2.959000

ATOMIC_POSITIONS angstrom
  Ti   0.000000   0.000000   0.000000
  Ti   2.297000   2.297000   1.479500
